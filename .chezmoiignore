# Machine-local state from update scripts (not config)
# Sidecar files track pre-update state for --rollback
src/*/.prev-rev
src/*/.prev-version
.local/bin/.*.prev-version
neovim/.prev-version

# git credential store — plaintext tokens, chezmoi must never manage/sync it
.git-credentials

# host-local git config (credential helpers), included from .gitconfig.
# Host-varying by nature: helper kinds and binary paths differ per machine.
.gitconfig.local
