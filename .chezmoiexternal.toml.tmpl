# This is a templated external config.
# DO NOT `chezmoi add` this as it already lives in the source dir.

{{ if eq .chezmoi.config.data.profile "workstation" }}
# Neovim repo to pull down every so often. Workstation only.
[".config/nvim"]
type = "git-repo"
url = "git@github.com:{{ .github_username }}/nvim.git"
refreshPeriod = "2h" # How often chezmoi should check for updates (e.g., "1h", "daily", "never")

# Recommended for clean pulls
[".config/nvim".pull]
args = ["--ff-only"]
{{ end }}

# Only grab the ZSH and tmux plugins on workstation or server-minimal, and only
# off-Windows. proxmox-host fetches nothing.
{{ if or (eq .chezmoi.config.data.profile "workstation") (eq .chezmoi.config.data.profile "server-minimal") }}
{{ if ne .chezmoi.os "windows" }}

# ZSH Plugins
#
# zsh-async plugin
[".zsh/plugins/zsh-async"]
type = "archive"
url = "https://github.com/mafredri/zsh-async/archive/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "672h" # How often chezmoi should check for updates (e.g., "1h", "daily", "never")

